{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-unverified-commits.sh",
            "statusMessage": "Checking git command policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-make-command.sh",
            "statusMessage": "Checking build command policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-splat-split.sh",
            "statusMessage": "Checking splat command policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-ctx-file.sh",
            "statusMessage": "Checking generated context file policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-temp-file.sh",
            "statusMessage": "Checking generated temp file policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-asm-edits.sh",
            "statusMessage": "Checking generated asm file policy"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-ctx-file.sh",
            "statusMessage": "Checking generated context file policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-temp-file.sh",
            "statusMessage": "Checking generated temp file policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-asm-edits.sh",
            "statusMessage": "Checking generated asm file policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-sha1-edits.sh",
            "statusMessage": "Checking checksum file policy"
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-docs-index.sh",
            "statusMessage": "Checking generated docs policy"
          }
        ]
      }
    ]
  }
}
